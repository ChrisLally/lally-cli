{
  "name": "@chris-lally/cli",
  "version": "0.1.0-alpha.26",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisLally/lally-cli"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "lally": "./dist/bin/lally.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm --filter @chris-lally/cli-fumadocs run build && pnpm exec tsup --config tsup.config.ts",
    "check-types": "pnpm --filter @chris-lally/cli-fumadocs run build && tsc --noEmit",
    "dev": "ts-node src/bin/lally.ts"
  },
  "devDependencies": {
    "@chris-lally/cli-fumadocs": "workspace:*",
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  }
}
