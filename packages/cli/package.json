{
  "name": "@chris-lally/cli",
  "version": "0.1.0-alpha.45",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChrisLally/lally-cli"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "lally": "./dist/bin/lally.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist *.tgz",
    "build": "pnpm run clean && pnpm exec tsup --config tsup.config.ts",
    "check-types": "tsc --noEmit",
    "dev": "ts-node src/bin/lally.ts",
    "verify:pack": "pnpm run build && npm pack --pack-destination ./dist",
    "verify:bundle": "pnpm run verify:pack && echo 'Checking for runtime workspace imports...' && sh -c '! grep -R --line-number --include=\"*.js\" \"@chris-lally/cli-\" dist'"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "5.9.2"
  }
}
