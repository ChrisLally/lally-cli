{
  "name": "@chris-lally/cli",
  "version": "0.1.0-alpha.24",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "lally": "./dist/bin/lally.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@chris-lally/cli-fumadocs": "workspace:*"
  },
  "scripts": {
    "build": "pnpm --filter @chris-lally/cli-fumadocs run build && rm -rf dist && tsc -p tsconfig.json",
    "check-types": "pnpm --filter @chris-lally/cli-fumadocs run build && tsc --noEmit",
    "dev": "ts-node src/bin/lally.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2"
  }
}
